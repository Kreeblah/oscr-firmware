+      override ENABLE_VSELECT :::= $(ENABLE_ONBOARD_ATMEGA)
+      # Set ENABLE_ONBOARD_ATMEGA to be 1 (on) rather than a specific voltage
+      override ENABLE_ONBOARD_ATMEGA = 1
+    else
+      # VSelect voltage specified does not match
+      $(error ERROR: Using flag ENABLE_VSELECT when specifying a voltage via ENABLE_ONBOARD_ATMEGA are mutually exclusive -- you can set only one; (ENABLE_VSELECT = $(ENABLE_VSELECT), ENABLE_ONBOARD_ATMEGA = $(ENABLE_ONBOARD_ATMEGA)))
+    endif
+  endif
+else
+  $(error ERROR: Flag ENABLE_ONBOARD_ATMEGA requires a value of 0 [off], 1 [on, implicit 3V3 mode], 3 [on, explicit 3V3 mode], or 5 [on, explicit 5V mode])
+endif
+
+#
+# [OSCR]
+# Set build flags for the integrated ATmega2560
+#
+ifeq ($(ENABLE_ONBOARD_ATMEGA),1)
+  # When off, turn VSelect on unless specifically requested not to
+  # These can never be non-zero at the same time, so if they are equal they must both be 0
+  ifeq ($(ENABLE_VSELECT),$(DISABLE_VSELECT))
+    override ENABLE_VSELECT = 1
+  endif
