+#reverse = $(if $(1),$(call reverse,$(wordlist 2,$(words $(1)),$(1)))) $(firstword $(1))
+
+reverse = $(let first rest,$1,$(if $(rest),$(call reverse,$(rest)) )$(first))
+
+define eq =
+$(strip \
+	$(eval $@_EQ_VAR = $($(1)))\
+	$(eval $@_EQ_LHS_COND = $(sort $(2)))\
+	$(eval $@_EQ_RHS_COND = $(call reverse,$($@_EQ_LHS_COND)))\
+	$(eval $@_EQ_LHS = $(findstring $($@_EQ_VAR),$($@_EQ_LHS_COND)))\
+	$(eval $@_EQ_RHS = $(findstring $($@_EQ_VAR),$($@_EQ_RHS_COND)))\
+	$(and $($@_EQ_LHS),$($@_EQ_RHS)) \
+)
+endef
+
+define oneof =
+$(strip \
+	$(eval $@_VAR=$(1))\
+	$(eval $@_VAR_COUNT=$(words $($@_VAR)))\
+	$(eval $@_VALUES1 =$(sort $(2)))\
+	$(eval $@_VALUES2=$(call reverse,$($@_VALUES1)))\
+	$(eval $@_CHK_COUNT=$(call eq,1,($($@_VAR_COUNT))))\
+	$(eval $@_CHK_VAL1=$(findstring $($@_VAR),$($@_VALUES1)))\
+	$(eval $@_CHK_VAL2=$(findstring $($@_VAR),$($@_VALUES2)))\
+	$(and $($@_CHK_COUNT),$($@_CHK_VAL1),$($@_CHK_VAL2),1) \
+)
+endef
+
+whichof = $(if $(call oneof,$(1),$(2)),$(1),)
+
+define conformto =
+	$(eval $@_VAR = $(1))
+	$(eval $@_VAL = $($(1)))
+	$(eval $@_WHICHOF = $(call whichof,$($@_VAL),$(2)))
+	override $(1) :::= $($@_WHICHOF)
+endef
+
+#
+# [OSCR]
+# Sanitize/validate DISABLE_VSELECT
+#
+ifeq ($(call oneof,$(DISABLE_VSELECT),0 1),1)
+  $(eval $(call conformto,DISABLE_VSELECT,0 1))
+else
+  $(error ERROR: Flag DISABLE_VSELECT requires a value of 0 [no change] or 1 [force disabled]; (DISABLE_VSELECT = $(DISABLE_VSELECT)))
+endif
+
+#
+# [OSCR]
+# Sanitize/validate ENABLE_VSELECT
+#
+ifeq ($(call oneof,$(ENABLE_VSELECT),0 1 3 5),1)
+  $(eval $(call conformto,ENABLE_VSELECT,0 1 3 5))
+
+  # Make sure ENABLE_VSELECT and DISABLE_VSELECT aren't both on.
+  ifneq ($(ENABLE_VSELECT),0)
+  ifeq ($(DISABLE_VSELECT),1)
+    $(error ERROR: Flags DISABLE_VSELECT and ENABLE_VSELECT are mutually exclusive -- you can set only one; (DISABLE_VSELECT = $(DISABLE_VSELECT), ENABLE_VSELECT = $(ENABLE_VSELECT)))
+  endif
+  endif
+else
