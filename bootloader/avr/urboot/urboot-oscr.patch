+endif
+
+#
+# [OSCR]
+# Set build flags for VSelect
+#
+ifneq ($(ENABLE_VSELECT),0)
+  # If VSELECT is 1 (on), replace with 3 for normal booting in 3V3 mode
+  ifeq ($(ENABLE_VSELECT),1)
+    override ENABLE_VSELECT = 3
+  endif
+
+  VSELECT_CMD = -DENABLE_VSELECT=$(ENABLE_VSELECT)
+endif
